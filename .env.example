# 把你的敏感資訊放在本機的 .env，切勿提交到版本控制
# 範例：
# Meta (Facebook) 設定
ACCESS_TOKEN=你的新長期TOKEN
AD_ACCOUNT_ID=act_你的帳號ID
META_APP_ID=你的APP_ID
META_APP_SECRET=你的APP_SECRET
META_OAUTH_REDIRECT_URI=http://localhost:3000/meta-token-callback.html

# Google Ads API 設定
GOOGLE_ADS_CLIENT_ID=你的OAUTH_CLIENT_ID
GOOGLE_ADS_CLIENT_SECRET=你的OAUTH_CLIENT_SECRET
GOOGLE_ADS_DEVELOPER_TOKEN=你的DEVELOPER_TOKEN
GOOGLE_ADS_REFRESH_TOKEN=你的REFRESH_TOKEN
GOOGLE_ADS_CUSTOMER_ID=你的廣告帳號ID(純數字)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=你的MCC帳號ID(通常與上面相同可不填)
GOOGLE_ADS_API_VERSION=v22

# 伺服器設定
PORT=3000